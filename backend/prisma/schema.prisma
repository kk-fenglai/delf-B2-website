// DELF B2 Platform - Prisma Schema (PostgreSQL — Neon in prod, local Postgres or Neon branch in dev)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  name              String?
  plan              String    @default("FREE")   // FREE | STANDARD | AI | AI_UNLIMITED
  subscriptionEnd   DateTime?

  // --- RBAC & Account status ---
  role              String    @default("USER")   // USER | ADMIN | SUPER_ADMIN
  status            String    @default("ACTIVE") // ACTIVE | SUSPENDED | DELETED
  deletedAt         DateTime?                    // soft-delete timestamp

  // --- Email verification ---
  emailVerified     Boolean   @default(false)
  emailVerifiedAt   DateTime?

  // --- Free trial (one-time AI_UNLIMITED grant, no payment) ---
  trialUsedAt       DateTime?

  // --- Login telemetry ---
  loginCount        Int       @default(0)
  lastLoginAt       DateTime?
  lastLoginIp       String?
  failedLoginCount  Int       @default(0)
  lockedUntil       DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  attempts              UserAttempt[]
  sessions              ExamSession[]
  essays                Essay[]
  recordings            Recording[]
  orals                 Oral[]
  essayTemplates        EssayTemplate[]
  loginHistory          LoginHistory[]
  resetTokens           PasswordResetToken[]
  twoFactorTokens       TwoFactorToken[]
  refreshTokens         RefreshToken[]
  emailVerifications    EmailVerificationToken[]
  adminLogs             AdminLog[]            @relation("AdminActor")
  paymentOrders         PaymentOrder[]
  subscriptions         Subscription[]
  payContracts          PayContract[]
  ownedExamSets         ExamSet[]             @relation("UserOwnedExamSets")

  @@index([role, status])
  @@index([plan, subscriptionEnd])
}

// ---------------- Payments & Billing ----------------

model Product {
  id          String   @id @default(cuid())
  code        String   @unique                 // STANDARD | AI | AI_UNLIMITED
  name        String
  plan        String                            // User.plan target value
  active      Boolean  @default(true)
  prices      Price[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Price {
  id                String         @id @default(cuid())
  productId         String
  product           Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  code              String         @unique      // STANDARD_1M | STANDARD_12M | AI_1M | ...
  // Optional human-readable label for admin UI / marketing copy (does not replace `code`).
  name              String?
  months            Int                           // 1 | 3 | 12
  currency          String         @default("CNY")
  amountCents       Int
  supportsAutoRenew Boolean        @default(false) // typically only monthly prices
  active            Boolean        @default(true)
  // Stripe Price ID (e.g. price_1Pxxxx). Required for Stripe `mode: 'subscription'`
  // checkout. One-time `mode: 'payment'` uses price_data inline so this can be null.
  stripePriceId     String?
  stripeMappings    PriceStripeMapping[]
  orders            PaymentOrder[]
  contracts         PayContract[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([productId, months, currency])
  @@index([productId, active])
}

model PriceStripeMapping {
  id           String   @id @default(cuid())
  priceId      String
  price        Price    @relation(fields: [priceId], references: [id], onDelete: Cascade)
  currency     String
  stripePriceId String  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([priceId, currency])
  @@index([currency])
}

model PaymentOrder {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // wechat | alipay | stripe
  provider         String
  // native_qr | page_pay | precreate_qr | autopay | stripe_checkout | stripe_subscription
  product          String

  // Our business intent
  plan             String
  months           Int       @default(1)

  // Link to configurable price (nullable for legacy rows)
  priceId          String?
  price            Price?    @relation(fields: [priceId], references: [id])

  // Link to contract when this order was generated by an auto-renew charge
  contractId       String?
  contract         PayContract? @relation(fields: [contractId], references: [id])

  // Money (store cents to avoid float)
  currency         String    @default("CNY")
  amountCents      Int

  status           String    @default("CREATED") // CREATED | PENDING | PAID | CLOSED | REFUNDED | FAILED
  externalTradeNo  String?   // transaction_id / trade_no
  providerOrderNo  String?   // out_trade_no
  refundedCents    Int       @default(0)

  // For QR products
  codeUrl          String?
  // For redirect products
  redirectUrl      String?

  paidAt           DateTime?
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  refunds          RefundOrder[]

  @@unique([provider, providerOrderNo])
  @@index([userId, createdAt])
  @@index([provider, status, createdAt])
  @@index([providerOrderNo])
  @@index([contractId])
}

model PayContract {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  priceId             String
  price               Price     @relation(fields: [priceId], references: [id])

  provider            String                    // wechat | alipay | stripe
  externalContractId  String    @unique         // wechat contract_id / alipay agreement_no / stripe sub id mirror

  // Stripe-only: customer + subscription identifiers used for Customer Portal
  // and admin force-cancel. Null for wechat/alipay rows.
  stripeCustomerId      String?
  stripeSubscriptionId  String?  @unique

  status              String    @default("PENDING") // PENDING | ACTIVE | TERMINATED | SUSPENDED
  nextChargeAt        DateTime?
  lastChargeAt        DateTime?
  failedCount         Int       @default(0)
  signedAt            DateTime?
  terminatedAt        DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  orders              PaymentOrder[]

  @@index([status, nextChargeAt])
  @@index([userId, status])
}

model RefundOrder {
  id               String        @id @default(cuid())
  orderId          String
  order            PaymentOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amountCents      Int
  reason           String?
  status           String        @default("PENDING") // PENDING | SUCCEEDED | FAILED
  externalRefundNo String?       @unique
  operatorAdminId  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([orderId, status])
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan            String
  status          String    @default("ACTIVE") // ACTIVE | CANCELLED | EXPIRED
  startedAt       DateTime  @default(now())
  currentPeriodEnd DateTime

  // If/when we support auto-renew contracts:
  autoRenew       Boolean   @default(false)
  provider        String?   // wechat | alipay
  contractId      String?   // agreement/contract identifier
  nextChargeAt    DateTime?

  sourceOrderId   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, status])
  @@index([autoRenew, nextChargeAt])
}

model RefreshToken {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash     String    @unique   // sha256 of raw refresh token
  scope         String                // "user" | "admin"
  parentId      String?               // previous token in rotation chain
  ip            String?
  userAgent     String?
  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason String?               // LOGOUT | ROTATED | REUSE_DETECTED | ADMIN_REVOKE | LOCKOUT
  createdAt     DateTime  @default(now())

  @@index([userId, scope, revokedAt])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, expiresAt])
}

// ---------------- Admin & Security ----------------

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation("AdminActor", fields: [adminId], references: [id])
  action     String   // USER_UPDATE | PLAN_CHANGE | PASSWORD_RESET | SUSPEND | DELETE | IMPERSONATE | LOGIN_2FA_OK ...
  targetType String   // USER | EXAM | SESSION | SYSTEM
  targetId   String?
  payload    String?  // JSON: before/after diff
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String?
  userAgent String?
  success   Boolean  @default(true)
  reason    String?  // BAD_PASSWORD | LOCKED | SUSPENDED | OK | TWO_FA_REQUIRED
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique            // sha256 of token; raw only sent via email
  expiresAt  DateTime
  usedAt     DateTime?
  requestedBy String?                    // USER | ADMIN:<adminId>
  ip         String?
  createdAt  DateTime @default(now())

  @@index([userId, expiresAt])
}

model TwoFactorToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String                        // sha256 of 6-digit code
  purpose   String   @default("ADMIN_LOGIN") // ADMIN_LOGIN | SENSITIVE_ACTION
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId, purpose, expiresAt])
}

// ---------------- Existing models (unchanged) ----------------

model ExamSet {
  id           String     @id @default(cuid())
  title        String
  year         Int?
  description  String?
  isPublished  Boolean    @default(true)
  isFreePreview Boolean   @default(false)
  // USER-owned sets: ownerUserId set, source=USER, primarySkill=CE|PE.
  // Platform catalog: ownerUserId null, source=PLATFORM.
  ownerUserId  String?
  owner        User?      @relation("UserOwnedExamSets", fields: [ownerUserId], references: [id], onDelete: Cascade)
  source       String     @default("PLATFORM") // PLATFORM | USER
  primarySkill String?    // CE | PE — single-skill user sets; null for platform/mocks
  createdAt    DateTime   @default(now())

  questions       Question[]
  sessions        ExamSession[]
  audioDocuments  AudioDocument[]

  @@index([ownerUserId, source])
  @@index([source, isPublished])
}

// One DELF B2 listening "document". Each Compréhension de l'Oral section has
// two of these (Ex.1: long, played twice; Ex.2: short, played once). Multiple
// questions share a document. Replaces the per-question audioUrl on CO so
// the runner can enforce DELF rules (plays, gap, prep time) at the right
// granularity.
model AudioDocument {
  id           String   @id @default(cuid())
  examSetId    String
  examSet      ExamSet  @relation(fields: [examSetId], references: [id], onDelete: Cascade)
  order        Int      @default(0)              // 0 = Exercise 1, 1 = Exercise 2, …
  title        String?                            // optional display name
  audioUrl     String?
  maxPlays     Int      @default(2)              // DELF: 2 for long, 1 for short
  prepSeconds  Int      @default(60)             // time to read questions before first play
  gapSeconds   Int      @default(180)            // silence between two plays (Ex.1 = 3 min)
  answerSeconds Int     @default(0)              // optional final answering window after last play
  createdAt    DateTime @default(now())

  questions    Question[]

  @@index([examSetId, order])
}

model ReadingPassage {
  id         String   @id @default(cuid())
  hash       String   @unique
  skill      String   @default("CE")
  title      String?
  content    String
  sourceFile String?
  createdAt  DateTime @default(now())

  questions  Question[]

  @@index([skill, createdAt])
}

model Question {
  id            String       @id @default(cuid())
  examSetId     String
  examSet       ExamSet      @relation(fields: [examSetId], references: [id], onDelete: Cascade)
  skill         String
  type          String
  order         Int          @default(0)
  prompt        String
  passage       String?
  passageId     String?
  readingPassage ReadingPassage? @relation(fields: [passageId], references: [id], onDelete: SetNull)
  // For CO questions, audio lives on the shared AudioDocument (see field
  // below). Question.audioUrl is kept for non-CO usages (none today, but
  // leave the column to avoid a destructive migration).
  audioUrl      String?
  audioDocumentId String?
  audioDocument AudioDocument? @relation(fields: [audioDocumentId], references: [id], onDelete: SetNull)
  explanation   String?
  // AI-generated detailed explanation for CO/CE objective questions, gated to
  // AI-plan users. Cached per language as JSON { zh?, en?, fr? } and shared
  // across all users (question content is identical for everyone).
  aiExplanation String?
  points        Int          @default(1)

  modelEssay    String?

  options       QuestionOption[]
  attempts      UserAttempt[]
  followUps     OralFollowUp[]
  essays        Essay[]

  @@index([examSetId, skill])
  @@index([passageId])
  @@index([audioDocumentId])
}

model QuestionOption {
  id          String   @id @default(cuid())
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label       String
  text        String
  isCorrect   Boolean  @default(false)
  order       Int      @default(0)

  @@index([questionId])
}

model ExamSession {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  examSetId    String
  examSet      ExamSet    @relation(fields: [examSetId], references: [id])
  mode         String     @default("PRACTICE")
  // For PRACTICE mode: CE | CO | PE | PO when single-skill, else null.
  // For EXAM mode: always null (full mock covers all skills).
  // Used by FREE-plan monthly quota bucketing in routes/sessions.js.
  skill        String?
  startedAt    DateTime   @default(now())
  completedAt  DateTime?
  totalScore   Int?
  maxScore     Int?

  attempts     UserAttempt[]

  @@index([userId, completedAt])
  @@index([userId, mode, skill, startedAt])
}

model UserAttempt {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId   String?
  session     ExamSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  questionId  String
  question    Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer      String
  isCorrect   Boolean?
  score       Int?
  timeSpent   Int?
  createdAt   DateTime     @default(now())

  @@index([userId, questionId])
}

model Essay {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  sessionId   String?                        // links back to the ExamSession for review join
  content     String
  wordCount   Int      @default(0)

  // --- AI grading state machine ---
  // queued   : just inserted, worker will pick up
  // grading  : worker claimed, Anthropic call in-flight
  // done     : rubric / corrections / aiScore populated
  // error    : errorMessage populated; user may retry via regrade
  status        String   @default("queued")
  model         String?                      // haiku-4-5 | sonnet-4-6 | opus-4-7
  locale        String?                      // fr | en | zh — feedback language chosen at submit
  aiScore       Int?                         // 0..25, recomputed server-side from rubric
  aiFeedback    String?                      // global narrative feedback
  rubric        String?                      // JSON: [{ key, score, max, feedback }] × 10
  corrections   String?                      // JSON: [{ excerpt, issue, suggestion, type }]
  strengths     String?                      // JSON: string[]
  tokensIn      Int?
  tokensOut     Int?
  tokensCached  Int?
  costUsd       Float?
  errorMessage  String?
  gradedAt      DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])              // worker scans queued/grading
  @@index([sessionId])
}

// ---------------- Oral / Production Orale ----------------
// Static follow-up questions per SPEAKING question — admin-curated. Read by
// the SpeakingExam page during the débat phase; passed to the LLM as scoring
// context (with `expectedAngle`) so it can judge the candidate's response.
model OralFollowUp {
  id            String   @id @default(cuid())
  questionId    String
  question      Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  order         Int      @default(0)
  text          String                       // 考官问题原文 (FR)
  audioUrl      String?                      // 可选 TTS 预录
  expectedAngle String?                      // 评分时给 LLM 的参考方向，不展示给学生

  @@index([questionId, order])
}

// One Recording row per uploaded audio blob. `followUpId == null` ⇒ the
// monologue (Partie 1); otherwise the answer to that follow-up (Partie 2).
// Audio file lives on disk under RECORDINGS_DIR; we never store binaries
// in the DB. Transcript is filled in by the oral worker.
model Recording {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId       String?
  questionId      String
  followUpId      String?
  audioPath       String                    // relative to RECORDINGS_DIR
  mimeType        String
  durationSec     Int       @default(0)
  sizeBytes       Int       @default(0)
  transcript      String?
  transcriptModel String?
  transcribedAt   DateTime?
  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([sessionId, questionId])
}

model Oral {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId    String?
  questionId   String

  // queued        : just inserted, waiting for STT pass
  // transcribing  : worker is calling DashScope ASR
  // grading       : transcripts done, LLM scoring in flight
  // done          : aiScore + rubric populated
  // error         : errorMessage populated; user may regrade
  status       String   @default("queued")
  model        String?
  locale       String?
  aiScore      Int?                          // 0..25 recomputed server-side
  aiFeedback   String?
  rubric       String?                       // JSON: [{key, score, max, feedback}]
  corrections  String?                       // JSON: [{excerpt, issue, suggestion, type}]
  strengths    String?                       // JSON: string[]
  transcriptCombined String?                 // monologue + each follow-up answer with markers
  recordingIds String?                       // JSON: [recId, ...] in playback order
  tokensIn     Int?
  tokensOut    Int?
  tokensCached Int?
  costUsd      Float?
  errorMessage String?
  gradedAt     DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([sessionId])
}

model EssayTemplate {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  type      String   @default("phrase")  // "phrase" | "structure"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}
