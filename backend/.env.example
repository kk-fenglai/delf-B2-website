# ─── Server ────────────────────────────────────────────────────────────────
PORT=4000
# development | production   (production enforces stricter env checks)
NODE_ENV=production
# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ─── Database (PostgreSQL — Neon in prod, local Postgres or Neon dev branch in dev) ──
# Neon dev branch URL works for local development too — saves running Postgres locally.
# Get a connection string from https://console.neon.tech (must include sslmode=require).
DATABASE_URL="postgresql://USER:PASS@HOST/delfluent?sslmode=require"
# Neon: use the *Direct* connection host (no "-pooler") — pooler breaks prisma migrate.

# ─── Frontend URL (CORS + email links) ────────────────────────────────────
FRONTEND_URL=https://your-domain.com

# ─── Payments ──────────────────────────────────────────────────────────────
# Default deploy is overseas-only via Stripe (Card + Stripe-hosted WeChat Pay
# + Stripe-hosted Alipay). The China-direct WeChat V3 / Alipay routes are
# disabled by default; flip these flags to true ONLY if you have:
#   - a Chinese mainland merchant entity (商户号),
#   - an ICP-filed callback domain pointed to PAY_PUBLIC_BASE_URL.
ENABLE_DIRECT_WECHAT=false
ENABLE_DIRECT_ALIPAY=false
#
# Public callback base (must be HTTPS + publicly reachable). REQUIRED only
# when ENABLE_DIRECT_WECHAT=true or ENABLE_DIRECT_ALIPAY=true.
# PAY_PUBLIC_BASE_URL=https://api.your-domain.com
#
# WeChat Pay V3 (Native QR)
# WECHAT_MCHID=
# WECHAT_SERIAL_NO=
# WECHAT_APIV3_KEY=
# WECHAT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# WECHAT_PLATFORM_CERT_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
#
# WeChat periodic payment (Papay / auto-renew)
# WECHAT_PAPAY_PLAN_ID=
#
# Alipay
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# ALIPAY_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
#
# Alipay auto-renew agreement period rule (JSON string)
# Example:
# ALIPAY_PERIOD_RULE_JSON={"period_type":"MONTH","period":1,"execute_time":"2026-01-01"}

# ─── JWT secrets (REQUIRED, 32+ chars each, MUST differ) ───────────────────
# Generate with:  openssl rand -hex 48
JWT_ACCESS_SECRET=REPLACE_WITH_openssl_rand_hex_48
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_openssl_rand_hex_48
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=14d
JWT_ADMIN_ACCESS_EXPIRES=30m
JWT_ADMIN_REFRESH_EXPIRES=2h

# ─── Admin bootstrap ──────────────────────────────────────────────────────
# Only used the first time `npm run seed` is run. Change immediately after
# first admin login. Must satisfy password policy (≥10 chars, 3+ classes).
ADMIN_INITIAL_PASSWORD=CHANGE_ME_On_First_Login_2026!

# Optional: comma-separated allowlist of IPs permitted to hit /api/admin/*.
# Strongly recommended in production.
# ADMIN_IP_ALLOWLIST=203.0.113.10,198.51.100.25

# ─── SMTP (REQUIRED in production — for email verification / 2FA / reset) ─
# 163.com (Chinese mainland-friendly):
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=alzy1210@163.com
# NOTE: this is the 163 "授权码 / authorization code" (not the login password)
SMTP_PASS=YOUR_163_AUTHORIZATION_CODE
SMTP_FROM=DELFluent <alzy1210@163.com>

# ─── AI grading providers (REQUIRED in production) ────────────────────────
# Essay grading uses DeepSeek (default tier) + Qwen (fast + premium tiers).
# Both are OpenAI-compatible; plan-tier gating + monthly per-user quotas are
# enforced server-side — see backend/src/constants/planMatrix.js.

# DeepSeek — https://platform.deepseek.com/api_keys  (must be ≥ 30 chars)
DEEPSEEK_API_KEY=
# Override only if Anthropic proxies you through a different endpoint.
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Qwen / Alibaba DashScope — optional; powers Qwen essay tiers only
# DASHSCOPE_API_KEY=

# Oral AI (Production Orale): Whisper STT + DeepSeek grading. Enabled by default.
# Set ENABLE_ORAL_AI=false to disable. Requires DEEPSEEK_API_KEY + OPENAI_API_KEY (Whisper).
# OPENAI_API_KEY=
# ENABLE_ORAL_AI=false
# Local dev: keep false when DATABASE_URL points at production Neon (default).
# Prevents local workers from stealing oral/essay jobs whose files live on Fly.io.
# RUN_BG_WORKERS=false
# Override only if you front DashScope behind your own gateway.
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Stripe (overseas checkout — Card + Adaptive Pricing)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...   # required for embedded checkout (Currency Selector)
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_ADAPTIVE_PRICING=true          # default; EUR anchor + local currency at checkout
# Anchor currency for Adaptive Pricing / Embedded Checkout display (default EUR).
# See 定价标准.md for official price list.
# STRIPE_ANCHOR_CURRENCY=EUR
# STRIPE_CHECKOUT_UI=embedded           # embedded (default) | hosted
# STRIPE_CHECKOUT_SUCCESS_URL=          # only used when STRIPE_CHECKOUT_UI=hosted
# STRIPE_CHECKOUT_CANCEL_URL=

# Free trial (no payment — AI_UNLIMITED for new verified users)
# TRIAL_ENABLED=true
# TRIAL_DAYS=3
# TRIAL_PLAN=AI_UNLIMITED

# Leave 'false' in production. Setting to 'true' lets `npm run seed` create
# demo users with weak passwords. NEVER set this on a customer-facing deploy.
ALLOW_PROD_SEED=false
